generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
}

model Post {
  id String @id @default(uuid())
  title String 
  content String
  status String
  type String 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String 
  user User @relation(fields: [userId], references: [id])
}

